<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="net.badmidi.ecms.AppController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Button fx:id="newSPS" onAction="#onNewPressed" text="New File"/>
    <Button fx:id="play" onAction="#onPlayPressed"/>
    <Label fx:id="badFileName"/>
    <TextField fx:id="filename"/>
    <Button fx:id="openFile" text="Open File" onAction="#onOpenFileButtonClick"/>
    <Button fx:id="createBasic" text="Create demo" onAction="#demo"/>    <Button fx:id="save" text="Save" onAction="#onSavePressed"/>


    <Canvas fx:id="editor"></Canvas>
</VBox>
